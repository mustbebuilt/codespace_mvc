<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Classroom</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="site-nav">
            <div class="site-nav__inner">
                <a class="site-nav__brand" asp-controller="Home" asp-action="Index">Classroom</a>
                <input type="checkbox" id="site-nav-toggle" class="site-nav__checkbox" aria-label="Toggle navigation" />
                <label for="site-nav-toggle" class="site-nav__toggle" aria-hidden="true">
                    <span></span><span></span><span></span>
                </label>
                <ul class="site-nav__links">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="Search">Search Students</a></li>
                    <li><a asp-controller="Students" asp-action="Index">Students</a></li>
                    <li><a asp-controller="Students" asp-action="Insert">Insert Student</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        &copy; 2026 Classroom App
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
