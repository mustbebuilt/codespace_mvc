@model IEnumerable<MyMvcApp.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h1>Students</h1>

<div class="table-wrap">
<table>
    <thead>
        <tr>
            <th>#</th>
            <th>Last Name</th>
            <th>First Name</th>
            <th>Email</th>
            <th>Date of Birth</th>
            <th>Enrolled</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td data-label="#">@student.StudentId</td>
                <td data-label="Last Name">@student.LastName</td>
                <td data-label="First Name">@student.FirstName</td>
                <td data-label="Email"><a href="mailto:@student.Email">@student.Email</a></td>
                <td data-label="Date of Birth">@(student.DateOfBirth?.ToString("dd MMM yyyy") ?? "—")</td>
                <td data-label="Enrolled">@student.EnrolledAt.ToString("dd MMM yyyy")</td>
                <td data-label="Actions" class="row-actions">
                    <a asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-sm">Edit</a>
                    <button type="button" class="btn btn-sm btn-danger"
                            onclick="confirmDelete(@student.StudentId, '@Html.Raw(student.FirstName + " " + student.LastName)')">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

<dialog id="delete-dialog">
    <form method="post" asp-action="Delete" id="delete-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="delete-id" />
        <h2>Delete Student</h2>
        <p>Are you sure you want to delete <strong id="delete-name"></strong>? This cannot be undone.</p>
        <div class="dialog-actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <button type="button" class="btn btn-secondary" onclick="document.getElementById('delete-dialog').close()">Cancel</button>
        </div>
    </form>
</dialog>

@section Scripts {
<script>
    function confirmDelete(id, name) {
        document.getElementById('delete-id').value = id;
        document.getElementById('delete-name').textContent = name;
        document.getElementById('delete-dialog').showModal();
    }
</script>
}
