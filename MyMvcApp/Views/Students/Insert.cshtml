@model MyMvcApp.Models.Student

@{
    ViewData["Title"] = "Insert Student";
}

<h1>Insert Student</h1>

<form method="post" asp-action="Insert" class="edit-form js-validate" novalidate>
    <div asp-validation-summary="ModelOnly" class="field-error"></div>

    <div class="form-field">
        <label asp-for="FirstName">First Name</label>
        <input asp-for="FirstName" required maxlength="50" />
        <span asp-validation-for="FirstName" class="field-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="LastName">Last Name</label>
        <input asp-for="LastName" required maxlength="50" />
        <span asp-validation-for="LastName" class="field-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" type="email" required maxlength="100" />
        <span asp-validation-for="Email" class="field-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="DateOfBirth">Date of Birth</label>
        <input asp-for="DateOfBirth" type="date" />
        <span asp-validation-for="DateOfBirth" class="field-error"></span>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn">Insert</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/form-validation.js" asp-append-version="true"></script>
}
